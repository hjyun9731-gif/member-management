# ============================================================
# Railway 배포용 환경변수 설정 가이드
# Railway 대시보드 > Variables 탭에서 아래 값들을 설정하세요
# ============================================================

# PostgreSQL 연결 URL
# Railway에서 PostgreSQL 플러그인 추가 시 자동으로 설정됩니다
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT 보안 키 (반드시 변경)
# python -c "import secrets; print(secrets.token_hex(32))" 로 생성
SECRET_KEY=반드시-변경하세요-긴-랜덤-문자열

# 토큰 설정
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 서버 포트 (Railway 자동 설정, 수동 입력 불필요)
# PORT=8000
